@using EatMyMoviesSite.DTOs
@model ListMovie;

<title>Eat My Movies - Discover Your Next Cinematic Obsession</title>
<meta name="description" content="Discover your next cinematic obsession with Eat My Movies – a curated compilation of top film rankings across diverse genres. Let our suggestions guide your movie nights and ignite your passion for storytelling. Explore a world of entertainment with random genre picks!" />

<form method="POST" action="/Movie/Detail">
    <section class="hero is-medium">
        <div>
            <div class="container has-text-centered">
                <h1>
                    Discover Your Next Cinematic Obsession
                </h1>

                <h2 class="subtitle has-text-weight-bold mb-0">
                    Recommender
                </h2>
                <button class="button mt-2"
                        asp-controller="Movie" 
                        asp-action="Recommender">
                    Take Me There
                </button>


                <h2 class="subtitle has-text-weight-bold pt-5">
                    Movie of the Week
                </h2>

                <article class="movie-block box mt-0 pb-6">
                    <div class="columns is-mobile">
                        <div class="column is-three-fifths">
                            <div class="content">
                                <h1 class="film-title">@Model.Title</h1>
                                <small>@Model.Genres</small><br />
                                <small>IMDB Rating: @Model.ImdbRating</small><br />
                                <a class="find-out-more" href="javascript:void(0);" onclick="window.location='@Url.Action("Detail", "Movie")?title=@(Model.Title)';">Find Out More</a>
                                <p class="synopsis desktop-only">@Model.Synopsis</p>
                            </div>
                        </div>
                        <div class="column is-two-fifths">
                            <img class="poster" src="@Model.PosterPath" alt="@Model.Title poster" />
                        </div>
                    </div>
                    <p class="synopsis mobile-only">@Model.Synopsis</p>
                </article>

                <h2 class="subtitle has-text-weight-bold pt-5 mb-0">
                    Popular Lists
                </h2>
                <div class="buttons is-centered mt-2">
                    <button class="button" asp-controller="List" asp-action="Top100">Top 100</button>
                    <button class="button" asp-controller="List" asp-action="Comedies">Comedies</button>
                    <button class="button" asp-controller="List" asp-action="ForeignFilms">Foreign Films</button>
                </div>
            </div>
        </div>
    </section>
</form>
