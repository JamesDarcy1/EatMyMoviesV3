@model HomeIndexViewModel
@{
    var movieOfTheWeek = Model.MovieOfTheWeek;
}

<title>Eat My Movies</title>
<meta name="description" content="Welcome to Eat My Movies - the place to discover your next cinematic obsession. By answering a few questions we aim to find you the perfect movie for your night's viewing. Please enjoy our recommendations and have fun exploring our carefully curated lists." />
<link rel="canonical" href="https://www.eatmymovies.com/" />

<div class="home-marquee-shell">
    <section class="home-cinema-hero" aria-labelledby="home-hero-title">
        <div class="home-hero-copy">
            <h1 id="home-hero-title" class="home-hero-title">
                Discover Your Next Cinematic Obsession
            </h1>
            <p class="home-hero-subtitle">
                Don't know what to watch tonight?
            </p>
            <a class="button is-primary home-hero-cta" asp-controller="Movie" asp-action="Recommender">
                Find me a movie
            </a>
        </div>
    </section>

    <section class="home-how-strip" aria-labelledby="how-it-works-title">
        <div class="home-section-heading">
            <span aria-hidden="true"></span>
            <h2 id="how-it-works-title">How it works</h2>
            <span aria-hidden="true"></span>
        </div>

        <ol class="home-step-list">
            <li class="home-step-card">
                <span class="home-step-icon" aria-hidden="true">
                    <svg viewBox="0 0 64 64" focusable="false">
                        <path d="M17 21h34l-5 34H22L17 21Z" />
                        <path d="M21 21 19 9l7 2 6-5 6 5 8-2-2 12" />
                        <path d="M28 27v20M39 27v20" />
                    </svg>
                </span>
                <span class="home-step-number">1</span>
                <strong>Tell us what you like</strong>
                <small>Answer a few quick questions about your taste in movies.</small>
            </li>
            <li class="home-step-card">
                <span class="home-step-icon" aria-hidden="true">
                    <svg viewBox="0 0 64 64" focusable="false">
                        <path d="M13 22h38v30H13V22Z" />
                        <path d="M13 22 48 12l4 11" />
                        <path d="m20 19 5 7m7-10 5 7m7-10 5 7" />
                        <path d="m29 31 12 7-12 7V31Z" />
                    </svg>
                </span>
                <span class="home-step-number">2</span>
                <strong>We find the perfect match</strong>
                <small>Our algorithm analyzes your preferences to find movies you'll love.</small>
            </li>
            <li class="home-step-card">
                <span class="home-step-icon" aria-hidden="true">
                    <svg viewBox="0 0 64 64" focusable="false">
                        <path d="M19 14h26v25H19V14Z" />
                        <path d="M15 39h34M23 39l-7 13M41 39l7 13M32 39v13" />
                        <path d="M24 20h16M24 27h16" />
                    </svg>
                </span>
                <span class="home-step-number">3</span>
                <strong>Enjoy your movie</strong>
                <small>Get your recommendation and enjoy your next great movie night.</small>
            </li>
        </ol>
    </section>

    @if (movieOfTheWeek != null)
    {
        <section class="home-feature-section" aria-labelledby="movie-of-week-title">
            <div class="home-section-heading home-section-heading-dark">
                <span aria-hidden="true"></span>
                <h2 id="movie-of-week-title">Movie of the Week</h2>
                <span aria-hidden="true"></span>
            </div>

            <article class="home-week-card">
                <a class="home-week-link" asp-controller="Movie" asp-action="Detail" asp-route-tmdbId="@movieOfTheWeek.TmdbId">
                    <div class="home-week-poster-wrap">
                        <img class="poster home-week-poster" src="@movieOfTheWeek.PosterPath" alt="@movieOfTheWeek.Title poster" loading="lazy" onerror="this.src='/icon_only.png'; this.classList.add('poster-fallback');" />
                    </div>
                    <div class="home-week-copy">
                        <h3>@movieOfTheWeek.Title</h3>
                        <p class="home-week-meta">
                            <span>@movieOfTheWeek.ReleaseDate</span>
                            <span>@movieOfTheWeek.Genres</span>
                            <span>IMDb @movieOfTheWeek.ImdbRating/10</span>
                            <span>@movieOfTheWeek.Runtime min</span>
                        </p>
                        <p class="home-week-synopsis">@movieOfTheWeek.Synopsis</p>
                        <span class="button is-primary home-week-cta">Find out more</span>
                    </div>
                </a>
            </article>
        </section>
    }

    <section class="home-list-section" aria-labelledby="movie-lists-title">
        <div class="home-section-heading">
            <span aria-hidden="true"></span>
            <h2 id="movie-lists-title">Movie Lists</h2>
            <span aria-hidden="true"></span>
        </div>
        <div class="list-button-grid home-list-board">
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Top100">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M8 4h8v3a4 4 0 0 1-8 0V4Z" />
                        <path d="M8 6H5a3 3 0 0 0 3 3M16 6h3a3 3 0 0 1-3 3" />
                        <path d="M12 11v4M9 20h6M10 15h4v5h-4z" />
                    </svg>
                </span>
                Top 100
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Christmas">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 3v18M4.5 7.5l15 9M19.5 7.5l-15 9" />
                        <path d="M8 5.5 12 8l4-2.5M8 18.5l4-2.5 4 2.5M4.8 12h14.4" />
                    </svg>
                </span>
                Christmas
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Comedies">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M5 5c4 1 10 1 14 0v6c0 5-3 8-7 8s-7-3-7-8V5Z" />
                        <path d="M8.5 10h.01M15.5 10h.01M8.5 14c1.6 1.5 5.4 1.5 7 0" />
                    </svg>
                </span>
                Comedies
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Disney">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="m4 20 10-10M12 8l4 4" />
                        <path d="M17 4v3M17 12v3M12.5 9.5h3M18.5 9.5h3M7 4l.8 1.8L10 6.5 7.8 7.2 7 9l-.8-1.8L4 6.5l2.2-.7L7 4Z" />
                    </svg>
                </span>
                Disney
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="ForeignFilms">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="12" cy="12" r="8" />
                        <path d="M4 12h16M12 4c2 2.2 3 4.9 3 8s-1 5.8-3 8M12 4c-2 2.2-3 4.9-3 8s1 5.8 3 8" />
                    </svg>
                </span>
                Foreign Films
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Documentaries">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M6 4h8l4 4v12H6V4Z" />
                        <path d="M14 4v4h4M9 12h6M9 16h4" />
                    </svg>
                </span>
                Documentaries
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="StandoutSoundtracks">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M9 18a2.5 2.5 0 1 1-2-2.45V6l10-2v11.5" />
                        <path d="M17 15.5a2.5 2.5 0 1 1-2-2.45M9 9l8-1.6" />
                    </svg>
                </span>
                Standout Soundtracks
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Iconic80s">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <rect x="4" y="6" width="16" height="12" rx="2" />
                        <path d="M8 15h8M8 10h8M9 18l1-3h4l1 3" />
                        <circle cx="8" cy="12.5" r="1.2" />
                        <circle cx="16" cy="12.5" r="1.2" />
                    </svg>
                </span>
                Iconic 80s
            </a>
            <a class="button list-button home-list-button" asp-controller="List" asp-action="Horrors">
                <span class="home-list-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M6 20V10a6 6 0 0 1 12 0v10l-3-2-3 2-3-2-3 2Z" />
                        <path d="M9.5 11h.01M14.5 11h.01M10 15c1.2-.8 2.8-.8 4 0" />
                    </svg>
                </span>
                Horrors
            </a>
        </div>
    </section>

    <section class="home-wheel-feature" aria-labelledby="home-wheel-title">
        <div class="home-wheel-copy">
            <span class="home-wheel-kicker">Movie night tiebreaker</span>
            <h2 id="home-wheel-title">Spin a movie night</h2>
            <p>When every pick sounds good, let the wheel call it.</p>
            <a class="button is-primary home-wheel-cta" asp-controller="Movie" asp-action="SpinTheWheel">
                Spin the wheel
            </a>
        </div>
        <div class="home-wheel-preview" aria-hidden="true">
            <div class="home-wheel-pointer"></div>
            <div class="home-wheel-reel">
                <span>Alien</span>
                <span>Clue</span>
                <span>Jaws</span>
                <span>Amelie</span>
            </div>
        </div>
    </section>
</div>
