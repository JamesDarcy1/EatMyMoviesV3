<!DOCTYPE html>
@{
	var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
	var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
	var isHomeActive = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
		&& string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
	var isAboutActive = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
		&& string.Equals(currentAction, "About", StringComparison.OrdinalIgnoreCase);
	var isListActive = string.Equals(currentController, "List", StringComparison.OrdinalIgnoreCase);
	var isAdminActive = string.Equals(currentController, "Admin", StringComparison.OrdinalIgnoreCase);
	var isAdminSignedIn = User.Identity?.IsAuthenticated == true && User.HasClaim("Admin", "true");
}
<html lang="en">
<head>
	<link rel="preconnect" href="https://image.tmdb.org" crossorigin>
	<link rel="dns-prefetch" href="https://image.tmdb.org">

	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<environment include="Development">
		<link rel="stylesheet" href="~/lib/bulma/css/bulma.css" />
	</environment>
	<environment exclude="Development">
		<link rel="stylesheet" href="~/lib/bulma/css/bulma.min.css" />
	</environment>
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/EatMyMoviesSite.styles.css" asp-append-version="true" />
	<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
	<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
	<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
	<link rel="manifest" href="/favicon/site.webmanifest">

	<!-- Hotjar Tracking Code for https://eatmymovies.com -->
	<script>
		(function (h, o, t, j, a, r) {
			h.hj = h.hj || function () { (h.hj.q = h.hj.q || []).push(arguments) };
			h._hjSettings = { hjid: 5171442, hjsv: 6 };
			a = o.getElementsByTagName('head')[0];
			r = o.createElement('script'); r.async = 1;
			r.src = t + h._hjSettings.hjid + j + h._hjSettings.hjsv;
			a.appendChild(r);
		})(window, document, 'https://static.hotjar.com/c/hotjar-', '.js?sv=');
	</script>
	<!-- Google Analytics Tracking Code -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-QGZDZJ5HW2"></script>
	<script>
		window.dataLayer = window.dataLayer || [];
		function gtag() { dataLayer.push(arguments); }
		gtag('js', new Date());
		gtag('config', 'G-QGZDZJ5HW2');
	</script>
</head>
<body class="bg mb-0">
	<header>
		<nav class="navbar header-box-shadow" role="navigation" aria-label="main navigation">
			<div class="navbar-brand has-text-centered">
				<a class="navbar-logo" asp-controller="Home" asp-action="Index" aria-label="Eat My Movies home">
					<img class="logo" src="~/no_background_logo.png" alt="Eat My Movies">
				</a>
				<a role="button" class="navbar-burger" aria-label="Open menu" aria-expanded="false" aria-controls="navbar-target" data-target="navbar-target" tabindex="0">
					<span aria-hidden="true"></span>
					<span aria-hidden="true"></span>
					<span aria-hidden="true"></span>
				</a>
			</div>

			<div id="navbar-target" class="navbar-menu">
				<div class="navbar-start">
					<a class="navbar-item @(isHomeActive ? "is-active" : null)" asp-controller="Home" asp-action="Index" aria-current="@(isHomeActive ? "page" : null)">Home</a>
					<div class="navbar-item has-dropdown is-hoverable nav-list-dropdown @(isListActive ? "is-active-route" : null)">
						<a class="navbar-link nav-list-toggle" role="button" aria-expanded="false" tabindex="0" aria-current="@(isListActive ? "page" : null)">
							Movie Lists
						</a>
						<div class="navbar-dropdown nav-list-menu">
							<a class="navbar-item" asp-controller="List" asp-action="Top100">
								Top 100
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Christmas">
								Christmas
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Comedies">
								Comedy
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Disney">
								Disney
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="ForeignFilms">
								Foreign Films
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Documentaries">
								Documentaries
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="StandoutSoundtracks">
								Standout Soundtracks
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Iconic80s">
								Iconic 80s
							</a>
							<a class="navbar-item" asp-controller="List" asp-action="Horrors">
								Horrors
							</a>
						</div>
					</div>
					<a class="navbar-item @(isAboutActive ? "is-active" : null)" asp-controller="Home" asp-action="About" aria-current="@(isAboutActive ? "page" : null)">About</a>
					@if (isAdminSignedIn)
					{
						<a class="navbar-item @(isAdminActive ? "is-active" : null)" asp-controller="Admin" asp-action="Index" aria-current="@(isAdminActive ? "page" : null)">Admin</a>
					}
				</div>
			</div>
		</nav>
	</header>
	<div class="container" id="vueAppTemplate">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<footer class="footer">
		<div class="has-text-centered">
			<strong>Eat My Movies</strong>. All rights reserved. <br />
				This product uses the TMDB API but is not endorsed or certified by TMDB
				<img class="tmdb-logo mt-3" src="~/TMDB_logo.svg" alt="Tmdb logo" />
		</div>
	</footer>

	<environment include="Development">
		<script src="~/lib/jquery/dist/jquery.js"></script>
	</environment>
	<environment exclude="Development">
		<script src="~/lib/jquery/dist/jquery.min.js"></script>
	</environment>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
	@RenderSection("VueComponents", required: false)

</body>
</html>
