@using EatMyMoviesSite.DTOs;
@using System.Diagnostics;
@model MovieDetail;

@if (Model != null)
{
    string posterUrl = "https://image.tmdb.org/t/p/w500" + Model.PosterPath;
    string formattedRuntime = "Unknown";

    if (Model.Runtime.HasValue)
    {
        int hrs = Model.Runtime.Value / 60;
        int mins = Model.Runtime.Value % 60;

        formattedRuntime = $"{hrs}h {mins}m";
    }

    <meta name="description" content="@Model.Overview" />
    <title>@Model.Title</title>

    <article class="marquee-result detail-marquee-detail" style="--poster-backdrop: url('@posterUrl')">
        <section class="marquee-hero detail-marquee-hero" aria-labelledby="movie-detail-title">
            <div class="marquee-hero-glow detail-marquee-glow" aria-hidden="true"></div>

            <div class="marquee-poster-frame detail-poster-frame">
                <img class="poster poster-on-detail marquee-poster detail-marquee-poster" src="@posterUrl" alt="@Model.Title poster" loading="lazy" onerror="this.src='/icon_only.png'; this.classList.add('poster-fallback');" />
            </div>

            <div class="marquee-hero-copy detail-hero-copy movie-detail-copy">
                <span class="marquee-kicker detail-kicker">Feature presentation</span>
                <h1 id="movie-detail-title" class="marquee-title detail-title">@Model.Title</h1>
                <p class="marquee-genres detail-genre-line">@Model.Genres</p>

                <div class="marquee-meta-rail detail-meta-rail" aria-label="Movie details">
                    <div class="marquee-meta-item detail-meta-item">
                        <span class="marquee-meta-label">Release</span>
                        <span class="marquee-meta-value">@Model.ReleaseDate</span>
                    </div>
                    @if (Model.ImdbRating != null)
                    {
                        <div class="marquee-meta-item detail-meta-item">
                            <span class="marquee-meta-label">IMDb</span>
                            <span class="marquee-meta-value">@Model.ImdbRating</span>
                        </div>
                    }
                    <div class="marquee-meta-item detail-meta-item">
                        <span class="marquee-meta-label">Runtime</span>
                        <span class="marquee-meta-value">@formattedRuntime</span>
                    </div>
                    <div class="marquee-meta-item detail-meta-item">
                        <span class="marquee-meta-label">Audio</span>
                        <span class="marquee-meta-value">@Model.Language</span>
                    </div>
                    <div class="marquee-meta-item detail-meta-item">
                        <span class="marquee-meta-label">Genres</span>
                        <span class="marquee-meta-value">@Model.Genres</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="marquee-copy detail-synopsis-section @(string.IsNullOrWhiteSpace(Model.Tagline) ? string.Empty : "has-tagline")">
            @if (!string.IsNullOrWhiteSpace(Model.Tagline))
            {
                <p class="marquee-tagline detail-tagline">"@Model.Tagline"</p>
            }
            <p class="synopsis marquee-synopsis movie-detail-overview detail-overview">@Model.Overview</p>
        </section>

        <section class="marquee-trailer detail-trailer-section" aria-label="Movie trailer">
            <div class="marquee-section-label detail-section-label">Trailer</div>
            <div class="marquee-trailer-screen detail-trailer-screen trailer-container">
                <iframe class="responsive-iframe"
                        src=@(Model.TrailerPath)
                        title="@Model.Title trailer"
                        allowfullscreen>
                </iframe>
            </div>
        </section>

        <section class="detail-people-section detail-director-panel" aria-labelledby="movie-detail-director">
            <div class="marquee-section-label detail-section-label">Director</div>
            <div class="box detail-marquee-panel">
                <h2 id="movie-detail-director" class="pb-2 mt-0">Director</h2>
                <div class="columns director-profile detail-director-profile">
                    <div class="column is-one-quarter detail-director-image">
                        <figure class="image is-flex is-justify-content-center">
                            <img class="profile-image is-rounded" src="@Model.Director.ProfilePath" alt="Director: @Model.Director.Name" loading="lazy" onerror="this.src='/icon_only.png'; this.classList.add('profile-fallback');">
                        </figure>
                    </div>
                    <div class="column detail-director-copy">
                        <p class="person-name">@Model.Director.Name</p>
                        <div class="director-section">
                            <p>@Model.Director.Biography</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="detail-people-section detail-cast-panel" aria-labelledby="movie-detail-cast">
            <div class="marquee-section-label detail-section-label">Cast</div>
            <div class="box detail-marquee-panel">
                <h2 id="movie-detail-cast" class="section-header mt-0 pb-2">Cast</h2>
                <div class="cast-grid detail-cast-grid">
                    @foreach (var actor in Model.Actors)
                    {
                        <div class="cast-card detail-cast-card">
                            <figure class="image is-flex is-justify-content-center">
                                <img class="profile-image is-rounded" src="@actor.ProfilePath" alt="@actor.Name" loading="lazy" onerror="this.src='/icon_only.png'; this.classList.add('profile-fallback');">
                            </figure>
                            <div class="actor-section">
                                <p class="person-name">@actor.Name</p>
                                <p><i>@actor.Character</i></p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    </article>

}
else
{
    <section class="movie-not-found" aria-labelledby="movie-not-found-title">
        <div class="movie-not-found-ticket">
            <p class="marquee-section-label movie-not-found-kicker">Feature unavailable</p>
            <h1 id="movie-not-found-title">Movie not found</h1>
            <p class="movie-not-found-copy">Please go back and try again.</p>
            <a class="button is-primary movie-not-found-action" asp-controller="Home" asp-action="Index">Back home</a>
        </div>
    </section>
}



