@page
@{
    Layout = "_Layout";
}

<title>Eat My Movies - Recommender</title>
<h1 class="logo-text">Recommender</h1>

<div id="recommenderApp" v-cloak>
    <transition name="fade">
        <div v-show="!showRecommendationBox" class="box has-text-centered">
            <div class="question-area">
                <loading-spinner v-if="isLoading"></loading-spinner>
                <div v-else>
                    <p v-if="!allQuestionsAnswered">{{ prompts[currentQuestionIndex] }}</p>
                    <div v-if="currentQuestionIndex === 0">
                        <!-- Genre Buttons -->
                        <div class="buttons is-centered mt-2">
                            <button v-for="genre in genres"
                                    :key="genre"
                                    :class="['button', { 'is-primary': selectedGenres.includes(genre) }]"
                                    v-on:click="toggleGenre(genre)">
                                {{ genre }}
                            </button>
                        </div>
                        <button class="button is-primary mt-2" v-on:click="handleYes">Next</button>
                    </div>

                    <div v-if="currentQuestionIndex === 1">
                        <!-- Duration Question -->
                        <div class="buttons is-centered">
                            <button v-for="(duration, index) in durations"
                                    :key="index"
                                    :class="['button', { 'is-primary': durationPreference === duration }]"
                                    v-on:click="selectDuration(index)">
                                {{ duration }}
                            </button>
                        </div>
                    </div>
                    <div v-if="currentQuestionIndex === 2">
                        <!-- Foreign Film Question -->
                        <button class="button"
                                :class="{ 'is-selected is-primary': openToForeignFilm === true }"
                                v-on:click="selectForeignFilm(true)">
                            Yes
                        </button>
                        <button class="button"
                                :class="{ 'is-selected is-primary': openToForeignFilm === false }"
                                v-on:click="selectForeignFilm(false)">
                            No
                        </button>
                    </div>
                    <div v-if="currentQuestionIndex === 3 && !allQuestionsAnswered">
                        <!-- Year Range Question -->
                        <div class="buttons is-centered">
                            <button v-for="(yearRange, index) in yearRanges"
                                    :key="index"
                                    :class="['button', { 'is-primary': releaseYearRange === yearRange }]"
                                    v-on:click="selectYearRange(index)">
                                {{ yearRange }}
                            </button>
                        </div>
                    </div>
                    <p v-if="allQuestionsAnswered && !loading && !recommendedMovie">No movie found matching your critia</p>
                </div>
            </div>
        </div>
    </transition>


    <!-- Movie Recommendation Box -->
    <transition name="slide">
        <div v-if="showRecommendationBox">
            <div class="buttons is-centered mt-4">
                <button class="button" v-on:click="loadNextRecommendation">Try Again</button>
                <button class="button" v-on:click="startOver">Start Over</button>
                <button class="button is-success" v-on:click="shareOnWhatsApp">Share on WhatsApp</button>
            </div>
            <div class="movie-area pt-3">
                <div class="box">
                    <loading-spinner v-if="isLoading"></loading-spinner>
                    <div v-else>
                        <div class="columns">
                            <div class="column is-three-fifths">
                                <h1 class="film-title">{{ recommendedMovie.title }}</h1>
                                <i class="tagline">{{ recommendedMovie.tagline }}</i><br />
                                <div class="columns is-mobile">
                                    <div class="column">
                                        <strong><u>Release Date</u></strong><br />
                                        <strong>{{ recommendedMovie.releaseDate }}</strong>
                                    </div>
                                    <div class="column">
                                        <strong><u>Runtime</u></strong><br />
                                        <strong>{{ recommendedMovie.runtime }} minutes</strong>
                                    </div>
                                    <div class="column">
                                        <strong><u>Imdb Rating</u></strong><br />
                                        <strong>{{ recommendedMovie.imdbRating }}</strong>
                                    </div>
                                </div>
                                <div class="columns is-mobile">
                                    <div class="column">
                                        <strong><u>Genres</u></strong><br />
                                        <strong>{{ recommendedMovie.genres }}<br></strong>
                                    </div>
                                </div>
                            </div>
                            <div class="column is-two-fifths">
                                <img class="poster-on-detail" :src="'https://image.tmdb.org/t/p/w500' + recommendedMovie.posterPath" :alt="recommendedMovie.title + ' poster'" />
                            </div>
                        </div>
                        <div class="column">
                            <div class="columns is-mobile">
                                <p class="synopsis">{{ recommendedMovie.overview }}</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div v-if="recommendedMovie" class="columns">
                    <div class="column has-text-centered trailer-container">
                        <iframe class="responsive-iframe" :src="recommendedMovie.trailerPath"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </transition>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.js"></script>
    <script src="/components/loading.js"></script>
    <script>
        const { createApp } = Vue;

        createApp({
            components: {
                'loading-spinner': LoadingSpinner
            },
            data() {
                return {
                    genres: [],
                    selectedGenres: [], // Store selected genres
                    currentQuestionIndex: 0,
                    maxQuestions: 4, // Number of questions after genre selection
                    recommendedMovie: null,
                    recommendationCollection: [],
                    genreSelected: false,
                    isLoading: true,
                    showRecommendationBox: false,
                    mood: null,
                    durationPreference: null,
                    openToForeignFilm: null,
                    releaseYearRange: null,
                    prompts: [
                        'Choose the 3 genres that appeal to you most right now.',
                        'Do you prefer a short movie or something longer?',
                        'Are you open to a film in a different language?',
                        'Do you want a movie from a specific release year range?'
                    ],
                    durations: ['Short (less than 2 hours)', 'Long (over 2 hours)', 'Any length'],
                    yearRanges: ['Before 2000', 'After 2000', 'Anytime'],
                    allQuestionsAnswered: false,
                    currentRecommendationIndex: 0 // Track current recommendation in the collection
                };
            },
            methods: {
                handleYes() {
                    if (this.currentQuestionIndex === 0) { // Genre selection
                        if (this.selectedGenres.length < 3) {
                            alert('Please select 3 genres.');
                            return;
                        }
                        this.genreSelected = true;
                        this.nextQuestion();
                    } else {
                        this.nextQuestion();
                        if (this.currentQuestionIndex === this.maxQuestions - 1) {
                            this.allQuestionsAnswered = true;
                            this.fetchRecommendedMovie();
                        }
                    }
                },
                toggleGenre(genre) {
                    const index = this.selectedGenres.indexOf(genre);
                    if (index > -1) {
                        // Remove genre
                        this.selectedGenres.splice(index, 1);
                    } else if (this.selectedGenres.length < 3) {
                        // Add genre
                        this.selectedGenres.push(genre);
                    }
                },
                handleNo() {
                    this.nextQuestion();
                },
                nextQuestion() {
                    this.currentQuestionIndex++;
                    if (this.currentQuestionIndex < this.maxQuestions) {
                        this.currentQuestion = this.prompts[this.currentQuestionIndex];
                    }
                },
                selectDuration(index) {
                    this.durationPreference = this.durations[index];
                    this.nextQuestion();
                },
                selectForeignFilm(value) {
                    this.openToForeignFilm = value;
                    this.nextQuestion();
                },
                selectYearRange(index) {
                    this.releaseYearRange = this.yearRanges[index];
                    this.allQuestionsAnswered = true;
                    this.fetchRecommendedMovie();
                },
                fetchRecommendedMovie() {
                    if (!this.allQuestionsAnswered) return;

                    this.isLoading = true;
                    const url = `/Movie/GetRecommendations?genres=${this.selectedGenres.join(',')}&duration=${this.durationPreference}&openToForeignFilm=${this.openToForeignFilm}&yearRange=${this.releaseYearRange}`;
                    fetch(url)
                        .then(response => response.json())
                        .then(data => {
                            this.recommendationCollection = data;
                            this.recommendedMovie = data[0];
                            this.currentRecommendationIndex = 0; // Reset recommendation index
                            this.isLoading = false;
                            this.showRecommendationBox = true;
                        });
                },
                loadNextRecommendation() {
                    if (this.currentRecommendationIndex < this.recommendationCollection.length - 1) {
                        this.currentRecommendationIndex++;
                        this.recommendedMovie = this.recommendationCollection[this.currentRecommendationIndex];
                    } else {
                        alert('No more recommendations available.');
                    }
                },
                startOver() {
                    this.showRecommendationBox = false;
                    this.currentQuestionIndex = 0;
                    this.selectedGenres = [];
                    this.allQuestionsAnswered = false;
                    this.recommendedMovie = null;
                    this.recommendationCollection = [];
                    this.currentRecommendationIndex = 0;
                },
                shareOnWhatsApp() {
                    const releaseYear = this.recommendedMovie.releaseDate.slice(-4);
                    const movieUrl = `www.eatmymovies.com/movie/detail?tmdbId=${this.recommendedMovie.tmdbId}`;
                    const message = `Check out this movie: ${this.recommendedMovie.title} (${releaseYear}) - ${movieUrl}`;
                    const url = `https://wa.me/?text=${encodeURIComponent(message)}`;
                    window.open(url, '_blank');
                }

            },
            mounted() {
                fetch('/Movie/GetGenres')
                    .then(response => response.json())
                    .then(data => {
                        this.genres = data;
                        this.currentQuestion = this.prompts[this.currentQuestionIndex];
                        this.isLoading = false;
                    });
            },
        }).mount('#recommenderApp');

    </script>
}

<style>
    [v-cloak] {
        display: none;
    }
</style>
