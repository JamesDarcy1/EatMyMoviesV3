<title>Find me a movie</title>
<meta name="description" content="We ask several questions, you tell us what you're looking for and we find the perfect movie recommendation" />

<div id="recommenderApp" class="recommender-panel recommender-marquee-page" v-cloak>
    <svg class="recommender-icon-sprite" aria-hidden="true" focusable="false">
        <symbol id="reco-icon-smile" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
            <path d="M9 9h.01"></path>
            <path d="M15 9h.01"></path>
        </symbol>
        <symbol id="reco-icon-sparkles" viewBox="0 0 24 24">
            <path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3Z"></path>
            <path d="M19 14l.9 2.1L22 17l-2.1.9L19 20l-.9-2.1L16 17l2.1-.9L19 14Z"></path>
            <path d="M5 15l.8 1.7L7.5 17.5l-1.7.8L5 20l-.8-1.7-1.7-.8 1.7-.8L5 15Z"></path>
        </symbol>
        <symbol id="reco-icon-droplet" viewBox="0 0 24 24">
            <path d="M12 2.5s6 6.4 6 11.2a6 6 0 0 1-12 0c0-4.8 6-11.2 6-11.2Z"></path>
        </symbol>
        <symbol id="reco-icon-brain" viewBox="0 0 24 24">
            <path d="M9 4.5A3.5 3.5 0 0 0 5.5 8v.5A3.5 3.5 0 0 0 4 15a3 3 0 0 0 3 3h2V4.5Z"></path>
            <path d="M15 4.5A3.5 3.5 0 0 1 18.5 8v.5A3.5 3.5 0 0 1 20 15a3 3 0 0 1-3 3h-2V4.5Z"></path>
            <path d="M9 9H7"></path>
            <path d="M15 9h2"></path>
            <path d="M9 14H7"></path>
            <path d="M15 14h2"></path>
        </symbol>
        <symbol id="reco-icon-eye" viewBox="0 0 24 24">
            <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z"></path>
            <circle cx="12" cy="12" r="3"></circle>
        </symbol>
        <symbol id="reco-icon-party" viewBox="0 0 24 24">
            <path d="M5 21l4.7-13.2L16.2 14 5 21Z"></path>
            <path d="M14 4l.5 2.5L17 7l-2.5.5L14 10l-.5-2.5L11 7l2.5-.5L14 4Z"></path>
            <path d="M19 2v3"></path>
            <path d="M21 4h-3"></path>
            <path d="M15 11l4-4"></path>
        </symbol>
        <symbol id="reco-icon-heart" viewBox="0 0 24 24">
            <path d="M20.8 5.6a5.2 5.2 0 0 0-7.4 0L12 7l-1.4-1.4a5.2 5.2 0 1 0-7.4 7.4L12 21l8.8-8a5.2 5.2 0 0 0 0-7.4Z"></path>
        </symbol>
        <symbol id="reco-icon-compass" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m15.5 8.5-2 5-5 2 2-5 5-2Z"></path>
        </symbol>
        <symbol id="reco-icon-planet" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4.5"></circle>
            <path d="M3 14c2.2 2.4 7.5 3.1 12.2 1.6C20 14.1 22.7 11 21 9c-1-1.2-3.1-1.5-5.6-1"></path>
            <path d="M21 9c-2.2-2.4-7.5-3.1-12.2-1.6C4 8.9 1.3 12 3 14c1 1.2 3.1 1.5 5.6 1"></path>
        </symbol>
        <symbol id="reco-icon-ghost" viewBox="0 0 24 24">
            <path d="M5 21V10a7 7 0 0 1 14 0v11l-3-2-2 2-2-2-2 2-2-2-3 2Z"></path>
            <path d="M9 10h.01"></path>
            <path d="M15 10h.01"></path>
        </symbol>
        <symbol id="reco-icon-laugh" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M8 14h8s-.7 3-4 3-4-3-4-3Z"></path>
            <path d="m8.5 9 1.5 1.5L11.5 9"></path>
            <path d="m12.5 9 1.5 1.5L15.5 9"></path>
        </symbol>
        <symbol id="reco-icon-clock" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="M12 7v5l3 2"></path>
        </symbol>
        <symbol id="reco-icon-globe" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20"></path>
            <path d="M12 2a15.3 15.3 0 0 1 0 20"></path>
            <path d="M12 2a15.3 15.3 0 0 0 0 20"></path>
        </symbol>
        <symbol id="reco-icon-calendar" viewBox="0 0 24 24">
            <path d="M7 2v4"></path>
            <path d="M17 2v4"></path>
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <path d="M3 10h18"></path>
        </symbol>
        <symbol id="reco-icon-arrow-left" viewBox="0 0 24 24">
            <path d="M19 12H5"></path>
            <path d="m12 19-7-7 7-7"></path>
        </symbol>
        <symbol id="reco-icon-arrow-right" viewBox="0 0 24 24">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
        </symbol>
        <symbol id="reco-icon-ticket-x" viewBox="0 0 24 24">
            <path d="M2 9a3 3 0 0 0 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 0 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2Z"></path>
            <path d="m9.5 9.5 5 5"></path>
            <path d="m14.5 9.5-5 5"></path>
        </symbol>
        <symbol id="reco-icon-popcorn" viewBox="0 0 24 24">
            <path d="M7 9h10l-1.5 12h-7L7 9Z"></path>
            <path d="M8 9 7 4l3 1 2-3 2 3 3-1-1 5"></path>
            <path d="M10 12v6"></path>
            <path d="M14 12v6"></path>
        </symbol>
    </svg>

    <transition name="fade">
        <section v-if="!showRecommendationBox" class="marquee-question-shell recommender-booth has-text-centered" aria-labelledby="recommender-question-title">
            <div class="recommender-booth-sign" aria-hidden="true">
                <span>Find Your Movie</span>
            </div>

            <div class="recommender-booth-frame">
                <div class="recommender-booth-lines" aria-hidden="true"></div>

                <header class="marquee-question-hero">
                    <div class="marquee-booth-title">
                        <span aria-hidden="true">*</span>
                        <strong id="recommender-question-title">Marquee Ticket Booth</strong>
                        <span aria-hidden="true">*</span>
                    </div>
                    <div class="progress-indicator marquee-progress-bulbs" aria-label="Question progress">
                        <button v-for="(question, index) in prompts"
                                :key="index"
                                type="button"
                                :class="['progress-step', 'marquee-progress-bulb', { 'is-current': currentQuestionIndex === index, 'is-complete': index < currentQuestionIndex, 'is-clickable': index <= currentQuestionIndex }]"
                                :aria-label="'Question ' + (index + 1)"
                                :aria-current="currentQuestionIndex === index ? 'step' : null"
                                :disabled="index > currentQuestionIndex || isLoading"
                                v-on:click="goToQuestion(index)">
                            {{ index + 1 }}
                        </button>
                    </div>
                    <p class="marquee-booth-helper">Answer a few questions. Get better recommendations.</p>
                </header>

                <div class="box question-card marquee-question-ticket">
                    <div class="question-area marquee-question-stage">
                        <div v-if="isLoading" class="marquee-ticket-loading">
                            <svg class="marquee-state-icon" aria-hidden="true" focusable="false">
                                <use href="#reco-icon-popcorn"></use>
                            </svg>
                            <p class="marquee-loading-copy">{{ allQuestionsAnswered ? 'Finding your next cinematic obsession...' : 'Opening the ticket booth...' }}</p>
                            <small>{{ allQuestionsAnswered ? "This won't take long." : 'Polishing the bulbs.' }}</small>
                            <loading-spinner></loading-spinner>
                        </div>
                        <div v-else-if="loadError" class="marquee-ticket-state marquee-ticket-error" role="alert">
                            <svg class="marquee-state-icon" aria-hidden="true" focusable="false">
                                <use href="#reco-icon-ticket-x"></use>
                            </svg>
                            <span class="marquee-ticket-step-label">Ticket jam</span>
                            <p class="question-prompt marquee-ticket-prompt">{{ loadError }}</p>
                            <small>Please try again.</small>
                            <div class="recommender-actions marquee-ticket-actions">
                                <button type="button" class="button recommender-nav-button marquee-ticket-next" v-on:click="retryAfterError">
                                    Try again
                                    <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-right"></use></svg>
                                </button>
                            </div>
                        </div>
                        <div v-else class="marquee-question-content">
                            <div class="marquee-ticket-question">
                                <div class="home-section-heading marquee-ticket-heading">
                                    <span aria-hidden="true"></span>
                                    <h2>Build your bill</h2>
                                    <span aria-hidden="true"></span>
                                </div>
                                <span v-if="!allQuestionsAnswered" class="marquee-ticket-step-label">Question {{ currentQuestionIndex + 1 }} of {{ maxQuestions }}</span>
                                <p v-if="!allQuestionsAnswered" class="question-prompt marquee-ticket-prompt">{{ prompts[currentQuestionIndex] }}</p>
                                <small v-if="currentQuestionIndex === 0">Select as many as you'd like.</small>
                                <small v-else-if="currentQuestionIndex === 3">Choose one.</small>
                                <small v-else>Choose one.</small>
                            </div>

                            <div v-if="currentQuestionIndex === 0" class="marquee-ticket-panel marquee-ticket-panel-feelings">
                                <div class="recommender-option-grid feeling-grid marquee-option-grid">
                                    <button v-for="feeling in feelings"
                                            type="button"
                                            :key="feeling"
                                            :class="['button recommender-option genre-button marquee-ticket-option', { 'is-primary': selectedFeelings.includes(feeling) }]"
                                            v-on:click="toggleFeeling(feeling)">
                                        <svg class="recommender-option-icon" aria-hidden="true" focusable="false">
                                            <use :href="'#' + iconForFeeling(feeling)"></use>
                                        </svg>
                                        <span>{{ formatFeeling(feeling) }}</span>
                                    </button>
                                </div>
                                <div class="recommender-actions marquee-ticket-actions marquee-sticky-cta">
                                    <button type="button" class="button recommender-nav-button marquee-ticket-next" :disabled="selectedFeelings.length === 0" v-on:click="nextQuestion()">
                                        Next
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-right"></use></svg>
                                    </button>
                                </div>
                            </div>

                            <div v-if="currentQuestionIndex === 1" class="marquee-ticket-panel">
                                <div class="buttons is-centered marquee-ticket-button-group">
                                    <button v-for="(duration, index) in durations"
                                            type="button"
                                            :key="index"
                                            :class="['button recommender-option wide-button marquee-ticket-option marquee-ticket-stub', { 'is-primary': durationPreference === duration }]"
                                            v-on:click="selectDuration(index)">
                                        <svg class="recommender-option-icon" aria-hidden="true" focusable="false">
                                            <use href="#reco-icon-clock"></use>
                                        </svg>
                                        <span>{{ duration }}</span>
                                    </button>
                                </div>
                                <div class="recommender-actions marquee-ticket-actions marquee-sticky-cta">
                                    <button type="button" class="button recommender-nav-button marquee-ticket-back" v-on:click="previousQuestion()">
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-left"></use></svg>
                                        Back
                                    </button>
                                    <button type="button" class="button recommender-nav-button marquee-ticket-next" :disabled="!durationPreference" v-on:click="nextQuestion()">
                                        Next
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-right"></use></svg>
                                    </button>
                                </div>
                            </div>

                            <div v-if="currentQuestionIndex === 2" class="marquee-ticket-panel">
                                <div class="buttons is-centered marquee-ticket-button-group">
                                    <button type="button"
                                            class="button recommender-option marquee-ticket-option marquee-ticket-stub"
                                            :class="{ 'is-selected is-primary': openToForeignFilm === true }"
                                            v-on:click="selectForeignFilm(true)">
                                        <svg class="recommender-option-icon" aria-hidden="true" focusable="false">
                                            <use href="#reco-icon-globe"></use>
                                        </svg>
                                        <span>Yes</span>
                                    </button>
                                    <button type="button"
                                            class="button recommender-option marquee-ticket-option marquee-ticket-stub"
                                            :class="{ 'is-selected is-primary': openToForeignFilm === false }"
                                            v-on:click="selectForeignFilm(false)">
                                        <svg class="recommender-option-icon" aria-hidden="true" focusable="false">
                                            <use href="#reco-icon-globe"></use>
                                        </svg>
                                        <span>No</span>
                                    </button>
                                </div>
                                <div class="recommender-actions marquee-ticket-actions marquee-sticky-cta">
                                    <button type="button" class="button recommender-nav-button marquee-ticket-back" v-on:click="previousQuestion()">
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-left"></use></svg>
                                        Back
                                    </button>
                                    <button type="button" class="button recommender-nav-button marquee-ticket-next" :disabled="openToForeignFilm === null" v-on:click="nextQuestion()">
                                        Next
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-right"></use></svg>
                                    </button>
                                </div>
                            </div>

                            <div v-if="currentQuestionIndex === 3 && !allQuestionsAnswered" class="marquee-ticket-panel">
                                <div class="buttons is-centered marquee-ticket-button-group">
                                    <button v-for="(yearRange, index) in yearRanges"
                                            type="button"
                                            :key="index"
                                            :class="['button recommender-option marquee-ticket-option marquee-ticket-stub', { 'is-primary': releaseYearRange === yearRange }]"
                                            v-on:click="selectYearRange(index)">
                                        <svg class="recommender-option-icon" aria-hidden="true" focusable="false">
                                            <use href="#reco-icon-calendar"></use>
                                        </svg>
                                        <span>{{ yearRange }}</span>
                                    </button>
                                </div>
                                <div class="recommender-actions marquee-ticket-actions marquee-sticky-cta">
                                    <button type="button" class="button recommender-nav-button marquee-ticket-back" v-on:click="previousQuestion()">
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-left"></use></svg>
                                        Back
                                    </button>
                                    <button type="button" class="button recommender-nav-button marquee-ticket-next" :disabled="!releaseYearRange" v-on:click="fetchRecommendedMovie()">
                                        Find me a movie
                                        <svg aria-hidden="true" focusable="false"><use href="#reco-icon-arrow-right"></use></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="recommender-booth-base" aria-hidden="true"></div>
            </div>
        </section>
    </transition>

    <div class="has-text-centered empty-recommendation marquee-empty-ticket" v-show="showRecommendationBox && !isLoading && !recommendedMovie">
        <svg class="marquee-state-icon" aria-hidden="true" focusable="false">
            <use href="#reco-icon-ticket-x"></use>
        </svg>
        <p>No movie found matching your criteria</p>
        <small>Try changing one answer and we will print a fresh ticket.</small>
        <button type="button" class="button recommendation-button" v-on:click="startOver">Start over</button>
    </div>

    <transition name="slide">
        <div v-if="showRecommendationBox && recommendedMovie" class="recommendation-result">
            <article class="marquee-result" :style="{ '--poster-backdrop': 'url(' + posterUrl(recommendedMovie.posterPath) + ')' }">
                <section class="marquee-hero" aria-labelledby="recommendation-title">
                    <div class="marquee-hero-glow" aria-hidden="true"></div>
                    <div class="marquee-poster-frame">
                        <img class="poster marquee-poster" :src="posterUrl(recommendedMovie.posterPath)" :alt="recommendedMovie.title + ' poster'" v-on:error="usePosterFallback" />
                        <div class="recommendation-action-stack" aria-label="Recommendation actions">
                            <button type="button" class="button recommendation-icon-button" :disabled="!hasNextRecommendation" v-on:click="loadNextRecommendation" aria-label="Next recommendation" title="Next recommendation">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M5 5v14l9-7-9-7z"></path>
                                    <path d="M17 5v14"></path>
                                </svg>
                            </button>
                            <button type="button" class="button recommendation-icon-button" v-on:click="startOver" aria-label="Start over" title="Start over">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M4 12a8 8 0 1 0 2.35-5.65"></path>
                                    <path d="M4 4v6h6"></path>
                                </svg>
                            </button>
                            <button type="button" class="button recommendation-icon-button" v-on:click="shareOnWhatsApp" aria-label="Share on WhatsApp" title="Share on WhatsApp">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <circle cx="18" cy="5" r="3"></circle>
                                    <circle cx="6" cy="12" r="3"></circle>
                                    <circle cx="18" cy="19" r="3"></circle>
                                    <path d="m8.6 10.6 6.8-4.2"></path>
                                    <path d="m8.6 13.4 6.8 4.2"></path>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="marquee-hero-copy">
                        <span class="marquee-kicker">Tonight's pick</span>
                        <h1 id="recommendation-title" class="marquee-title">{{ recommendedMovie.title }}</h1>
                        <p class="marquee-genres">{{ recommendedMovie.genres }}</p>
                        <div class="marquee-meta-rail" aria-label="Movie details">
                            <div class="marquee-meta-item">
                                <span class="marquee-meta-label">Year</span>
                                <span class="marquee-meta-value">{{ releaseYear(recommendedMovie.releaseDate) }}</span>
                            </div>
                            <div class="marquee-meta-item">
                                <span class="marquee-meta-label">IMDb</span>
                                <span class="marquee-meta-value">{{ recommendedMovie.imdbRating }}</span>
                            </div>
                            <div class="marquee-meta-item">
                                <span class="marquee-meta-label">Time</span>
                                <span class="marquee-meta-value">{{ runtimeLabel(recommendedMovie.runtime) }}</span>
                            </div>
                            <div class="marquee-meta-item">
                                <span class="marquee-meta-label">Audio</span>
                                <span class="marquee-meta-value">{{ recommendedMovie.language }}</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="marquee-copy" :class="{ 'has-tagline': recommendedMovie.tagline }">
                    <p v-if="recommendedMovie.tagline" class="marquee-tagline">"{{ recommendedMovie.tagline }}"</p>
                    <p class="synopsis marquee-synopsis">{{ recommendedMovie.overview }}</p>
                </section>

                <section v-if="recommendedMovie.trailerPath" class="marquee-trailer" aria-label="Movie trailer">
                    <div class="marquee-section-label">Trailer</div>
                    <div class="marquee-trailer-screen">
                        <iframe class="responsive-iframe" :src="recommendedMovie.trailerPath" title="Movie trailer" allowfullscreen></iframe>
                    </div>
                </section>

                <section v-else class="marquee-trailer marquee-trailer-empty" aria-label="Movie trailer unavailable">
                    <div class="marquee-section-label">Trailer</div>
                    <div class="marquee-trailer-screen">
                        <p>No trailer available</p>
                    </div>
                </section>
            </article>

        </div>
    </transition>
</div>

@section Scripts {
    <script src="~/lib/vue/vue.global.prod.js"></script>
    <script src="/components/loading.js"></script>
    <script>
        const { createApp } = Vue;

        createApp({
            components: {
                'loading-spinner': LoadingSpinner
            },
            data() {
                return {
                    feelings: [],
                    selectedFeelings: [],
                    currentQuestionIndex: 0,
                    maxQuestions: 4,
                    recommendedMovie: null,
                    recommendationCollection: [],
                    isLoading: true,
                    showRecommendationBox: false,
                    durationPreference: null,
                    openToForeignFilm: null,
                    releaseYearRange: null,
                    loadError: '',
                    prompts: [
                        'What kind of feeling or experience are you looking for in a movie right now?',
                        'How long do you want to watch for?',
                        'Are you open to a movie in another language?',
                        'Do you want a movie from a specific release year range?'
                    ],
                    durations: ['Short (less than 2 hours)', 'Long (over 2 hours)', 'Any length'],
                    yearRanges: ['Before 2000', 'After 2000', 'Anytime'],
                    allQuestionsAnswered: false,
                    currentRecommendationIndex: 0
                };
            },
            computed: {
                hasNextRecommendation() {
                    return this.currentRecommendationIndex < this.recommendationCollection.length - 1;
                }
            },
            methods: {
                toggleFeeling(feeling) {
                    const index = this.selectedFeelings.indexOf(feeling);
                    if (index > -1) {
                        this.selectedFeelings.splice(index, 1);
                    } else {
                        this.selectedFeelings.push(feeling);
                    }
                },
                formatFeeling(feeling) {
                    return feeling.replace(/([a-z])([A-Z])/g, '$1 $2');
                },
                iconForFeeling(feeling) {
                    const icons = {
                        FeelGood: 'reco-icon-smile',
                        Inspiring: 'reco-icon-sparkles',
                        Emotional: 'reco-icon-droplet',
                        MindBending: 'reco-icon-brain',
                        Mysterious: 'reco-icon-eye',
                        Silly: 'reco-icon-party',
                        Romantic: 'reco-icon-heart',
                        Adventurous: 'reco-icon-compass',
                        Weird: 'reco-icon-planet',
                        Scary: 'reco-icon-ghost',
                        Funny: 'reco-icon-laugh'
                    };

                    return icons[feeling] || 'reco-icon-sparkles';
                },
                nextQuestion() {
                    if (this.currentQuestionIndex < this.maxQuestions - 1) {
                        this.currentQuestionIndex++;
                    }
                },
                previousQuestion() {
                    if (this.currentQuestionIndex > 0) {
                        this.currentQuestionIndex--;
                    }
                },
                selectDuration(index) {
                    this.durationPreference = this.durations[index];
                },
                selectForeignFilm(value) {
                    this.openToForeignFilm = value;
                },
                selectYearRange(index) {
                    this.releaseYearRange = this.yearRanges[index];
                },
                fetchRecommendedMovie() {
                    this.allQuestionsAnswered = true;
                    this.isLoading = true;
                    this.loadError = '';

                    const feelingsParam = this.selectedFeelings.join(',');
                    const url = `/Movie/GetRecommendations?feelings=${encodeURIComponent(feelingsParam)}&duration=${encodeURIComponent(this.durationPreference)}&openToForeignFilm=${this.openToForeignFilm}&yearRange=${encodeURIComponent(this.releaseYearRange)}`;

                    fetch(url)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Recommendation failed');
                            }
                            return response.json();
                        })
                        .then(data => {
                            this.recommendationCollection = Array.isArray(data) ? data : [];
                            this.recommendedMovie = this.recommendationCollection[0] || null;
                            this.currentRecommendationIndex = 0;
                            this.showRecommendationBox = true;
                        })
                        .catch(() => {
                            this.loadError = 'Recommendations are unavailable. Please try again.';
                            this.recommendedMovie = null;
                            this.showRecommendationBox = false;
                            this.allQuestionsAnswered = false;
                        })
                        .finally(() => {
                            this.isLoading = false;
                        });
                },
                retryAfterError() {
                    if (this.selectedFeelings.length > 0 && this.durationPreference && this.openToForeignFilm !== null && this.releaseYearRange) {
                        this.fetchRecommendedMovie();
                        return;
                    }

                    window.location.reload();
                },
                loadNextRecommendation() {
                    if (this.hasNextRecommendation) {
                        this.currentRecommendationIndex++;
                        this.recommendedMovie = this.recommendationCollection[this.currentRecommendationIndex];
                    }
                },
                startOver() {
                    this.showRecommendationBox = false;
                    this.currentQuestionIndex = 0;
                    this.selectedFeelings = [];
                    this.durationPreference = null;
                    this.openToForeignFilm = null;
                    this.releaseYearRange = null;
                    this.allQuestionsAnswered = false;
                    this.recommendedMovie = null;
                    this.recommendationCollection = [];
                    this.currentRecommendationIndex = 0;
                    this.loadError = '';
                },
                shareOnWhatsApp() {
                    const releaseYear = this.recommendedMovie.releaseDate.slice(-4);
                    const movieUrl = `www.eatmymovies.com/movie/detail?tmdbId=${this.recommendedMovie.tmdbId}`;
                    const message = `Check out this movie: ${this.recommendedMovie.title} (${releaseYear}) - ${movieUrl}`;
                    const url = `https://wa.me/?text=${encodeURIComponent(message)}`;
                    window.open(url, '_blank', 'noopener');
                },
                goToQuestion(index) {
                    if (index <= this.currentQuestionIndex) {
                        this.currentQuestionIndex = index;
                    }
                },
                releaseYear(releaseDate) {
                    const releaseText = releaseDate ? releaseDate.toString() : '';
                    const match = releaseText.match(/\b(19|20)\d{2}\b/);
                    return match ? match[0] : releaseText;
                },
                runtimeLabel(runtime) {
                    return runtime ? `${runtime} min` : 'TBC';
                },
                usePosterFallback(event) {
                    if (!event.target.src.endsWith('/icon_only.png')) {
                        event.target.src = '/icon_only.png';
                        event.target.classList.add('poster-fallback');
                    }
                },
                posterUrl(posterPath) {
                    return posterPath ? `https://image.tmdb.org/t/p/w500${posterPath}` : '/icon_only.png';
                }
            },
            mounted() {
                fetch('/movie/GetFeelings')
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Feelings failed');
                        }
                        return response.json();
                    })
                    .then(data => {
                        this.feelings = data;
                    })
                    .catch(() => {
                        this.loadError = 'Movie questions are unavailable. Please refresh and try again.';
                    })
                    .finally(() => {
                        this.isLoading = false;
                    });
            }
        }).mount('#recommenderApp');
    </script>
}
