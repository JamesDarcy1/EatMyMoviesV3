@model PaginationViewModel

<nav class="pagination is-centered mt-5" role="navigation" aria-label="pagination">
    <ul class="pagination-list">
        @if (Model.CurrentPage > 1)
        {
            <li>
                <a class="pagination-link" href="@Url.Action(Model.ActionName, new { page = Model.CurrentPage - 1 })">Previous</a>
            </li>
        }
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li>
                <a class="pagination-link @(i == Model.CurrentPage ? "is-current" : "")" href="@Url.Action(Model.ActionName, new { page = i })">@i</a>
            </li>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <li>
                <a class="pagination-link" href="@Url.Action(Model.ActionName, new { page = Model.CurrentPage + 1 })">Next</a>
            </li>
        }
    </ul>
</nav>
