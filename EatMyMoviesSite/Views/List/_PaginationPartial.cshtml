@model PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav class="pagination is-centered mt-5" role="navigation" aria-label="pagination">
        <ul class="pagination-list">
            @if (Model.CurrentPage > 1)
            {
                <li>
                    <a class="pagination-link" href="@Url.Action(Model.ActionName, new { page = 1 })" aria-label="Go to page 1">
                        1
                    </a>
                </li>
            }

            <li>
                <span class="pagination-link pagination-current is-current" aria-current="page">Page @Model.CurrentPage of @Model.TotalPages</span>
            </li>

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li>
                    <a class="pagination-link pagination-step-link pagination-next-link" href="@Url.Action(Model.ActionName, new { page = Model.CurrentPage + 1 })" aria-label="Go to next page">
                        <span class="pagination-step-text">Next</span>
                        <span class="pagination-step-icon" aria-hidden="true">&rsaquo;</span>
                    </a>
                </li>
            }
        </ul>
    </nav>
}
