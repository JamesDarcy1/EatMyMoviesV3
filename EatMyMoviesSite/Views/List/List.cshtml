@using EatMyMoviesSite.DTOs;
@model MovieList

<div class="has-text-centered">
	<h1>@Model.Name</h1>

	<p>
		Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla eget pharetra arcu. Maecenas vestibulum porta orci, convallis rhoncus velit tincidunt vitae. Cras mollis pellentesque tortor, quis tristique enim varius vel. Class aptent taciti sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos. Morbi dolor odio, ultricies non mauris ut, dapibus pulvinar elit. Fusce mauris arcu, aliquam eget lobortis a, mollis aliquam neque. Aenean ac felis facilisis, tempor urna sit amet, tempus lorem. Quisque condimentum augue sed elit interdum lobortis. Fusce pretium fringilla vulputate. In dictum convallis diam, ac consequat justo hendrerit nec. Suspendisse iaculis at felis a volutpat. Morbi eget nibh eget nibh ultricies rhoncus ac nec mauris. Donec bibendum felis at sagittis scelerisque. Aenean dolor turpis, elementum at sollicitudin ac, hendrerit eget nisi. Curabitur at lectus ornare, tristique dui ut, sollicitudin erat. Sed laoreet turpis elit, id finibus velit commodo in.
	</p>
	<div class="opaque-box is-paddingless">
		<table class="table is-narrow is-fullwidth has-text-weight-bold has-text-centerd">
			<thead class="is-white">
				<tr>
					<th></th>
					<th class="has-text-centered">Title</th>
					<th class="has-text-centered">Poster</th>
					<th class="has-text-centered">IMDB Rating</th>
					<th class="has-text-centered">Genre</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var movie in Model.Movies)
				{
					<tr onclick="window.location='@Url.Action("Detail", "Movie")?title=@(movie.Title)';" class="is-clickable">
						<td class="is-center has-text-weight-bold">@movie.Ranking</td>
						<td class="movie-title">@movie.Title</td>
						<td><img src="@movie.PosterPath" alt="Sample Photo" class="poster" /></td>
						<td>
							@movie.ImdbRating
						</td>
						<td>
							@foreach (var genre in movie.Genres)
							{
								@genre

								<br />
							}
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>
@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
	{
	CurrentPage = Model.CurrentPage,
	TotalPages = Model.TotalPages,
	ActionName = Model.Name.Replace( " ", "" )
	})
