@using EatMyMoviesSite.DTOs;
@model MovieList

<meta name="description" content=@Model.Description />
<title>@Model.Name - Eat My Movies</title>

<div class="has-text-centered">
    <h1>@Model.Name</h1>
    <p>
        @Model.Description
    </p> <br />

    @foreach (var movie in Model.Movies)
    {
        <h1>@movie.Ranking</h1>
        <article class="movie-block box mt-0 pb-0">
            <div class="columns is-mobile is-hidden-desktop mb-0">
                <div class="column is-one-third column is-one-third is-flex is-align-items-center is-justify-content-center">
                    <img class="poster" src="@movie.SmallPosterPath" alt="@movie.Title poster" />
                </div>
                <div class="column is-two-thirds is-flex is-flex-direction-column is-justify-content-center">
                    <h4 class="movie-title mb-0">@movie.Title</h4>
                    <small class="release-date">@movie.ReleaseDate</small>
                    <small>@movie.Genres</small>
                    <small>@movie.ImdbRating IMDB Rating</small>
                    <small>@movie.Runtime Minutes</small>
                    <small>@movie.Language</small>
                    <a class="find-out-more" href="javascript:void(0);" onclick="window.location='@Url.Action("Detail", "Movie")?title=@(movie.Title)';">Find Out More</a>
                </div>
            </div>

            <div class="columns is-desktop is-hidden-mobile">
                <div class="column is-one-third is-flex is-align-items-center is-justify-content-center">
                    <img class="poster-on-detail" src="@movie.LargePosterPath" alt="@movie.Title poster" />
                </div>
                <div class="column is-one-thirds is-flex is-flex-direction-column is-justify-content-center">
                    <h4 class="movie-title mb-0">@movie.Title</h4>
                    <small class="release-date">@movie.ReleaseDate</small>
                    <small>@movie.Genres</small>
                    <small>@movie.ImdbRating IMDB Rating</small>
                    <small>@movie.Runtime Minutes</small>
                    <small>@movie.Language</small>
                    <a class="find-out-more" href="javascript:void(0);" onclick="window.location='@Url.Action("Detail", "Movie")?title=@(movie.Title)';">Find Out More</a>
                </div>
                <div class="column is-one-third is-flex is-flex-direction-column is-justify-content-center">
                    <small>@movie.Synopsis</small>
                </div>
            </div>

        </article>
    }

</div>
@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    CurrentPage = Model.CurrentPage,
    TotalPages = Model.TotalPages,
    ActionName = Model.Name.Replace(" ", "")
})
