@using EatMyMoviesSite.DTOs;
@model MovieList

<meta name="description" content=@Model.Description />
<title>@Model.Name</title>

<div class="has-text-centered">
    <h1>@Model.Name</h1>
    <p>
        @Model.Description
    </p> <br />

    @foreach (var movie in Model.Movies)
    {
        <h1>@movie.Ranking</h1>
        <article class="movie-block mt-0">
            <a class="clickable-card" onclick="window.location='@Url.Action("Detail", "Movie")?tmdbId=@(movie.TmdbId)';">
                <div class="columns is-mobile m-0">
                    <div class="column is-two-fifths-mobile is-one-third-desktop is-flex is-align-items-center is-justify-content-center">
                        <img class="poster" src="@movie.PosterPath" alt="@movie.Title poster" />
                    </div>
                    <div class="column is-one-third-desktop is-justify-content-center">
                        <h4 class="movie-title mb-0">@movie.Title</h4>
                        <small class="release-date">@movie.ReleaseDate</small>
                        <small>@movie.Genres</small>
                        <small>@movie.ImdbRating IMDB Rating</small>
                        <small>@movie.Runtime Minutes</small>
                        <small>@movie.Language</small>
                        <small class="find-out-more">Find Out More</small>
                    </div>
                    <div class="column is-one-third-desktop is-hidden-mobile is-flex is-flex-direction-column is-justify-content-center">
                        <small class="card-synopsis">@movie.Synopsis</small>
                    </div>
                </div>
            </a>

        </article>
    }

</div>
@await Html.PartialAsync("_PaginationPartial", new PaginationViewModel
{
    CurrentPage = Model.CurrentPage,
    TotalPages = Model.TotalPages,
    ActionName = Model.Name.Replace(" ", "")
})
